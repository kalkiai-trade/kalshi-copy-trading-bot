# Follower wallet (receiver of mirrored trades)
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PATH=
# Optional inline PEM alternative to file path:
# KALSHI_PRIVATE_KEY_PEM=

# Prod vs demo routing
KALSHI_DEMO=false
# KALSHI_BASE_PATH=

# Leader wallet (fills we mirror)
KALSHI_LEADER_API_KEY=
KALSHI_LEADER_PRIVATE_KEY_PATH=
# OR
# KALSHI_LEADER_PRIVATE_KEY_PEM=
# Override when routing leader traffic differently than follower:
# KALSHI_LEADER_BASE_PATH=

# Copy knobs
COPY_POLL_INTERVAL_MS=3000
COPY_POLL_LIMIT=50
COPY_SIZE_MULTIPLIER=1
# COPY_MIN_TS=
COPY_START_LOOKBACK_SEC=120
COPY_MAX_CONTRACTS=1000000
COPY_DRY_RUN=false
